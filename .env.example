# # ────────────────────────────────────────────────────────────────────────────
# # Database Configuration
# # ────────────────────────────────────────────────────────────────────────────
# MONGODB_URL=mongodb://admin:password@mongodb:27017/ajpropl?authSource=admin

# # ────────────────────────────────────────────────────────────────────────────
# # Redis Configuration
# # ────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379

# # ────────────────────────────────────────────────────────────────────────────
# # Gemini AI API
# # ────────────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here

# # ────────────────────────────────────────────────────────────────────────────
# # Cloudflare R2 Storage
# # ────────────────────────────────────────────────────────────────────────────
# R2_ACCESS_KEY_ID=your_r2_access_key_here
# R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
# R2_BUCKET_NAME=your_bucket_name
# R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# # ────────────────────────────────────────────────────────────────────────────
# # Replicate API (Virtual Try-On, Mannequin, Model)
# # ────────────────────────────────────────────────────────────────────────────
# REPLICATE_API_TOKEN=your_replicate_token_here

# # ────────────────────────────────────────────────────────────────────────────
# # HuggingFace Hub
# # ────────────────────────────────────────────────────────────────────────────
# HF_TOKEN=your_huggingface_token_here

# # ────────────────────────────────────────────────────────────────────────────
# # Application Settings
# # ────────────────────────────────────────────────────────────────────────────
# DEBUG=false
# LOG_LEVEL=info
# PYTHONUNBUFFERED=1

# # ────────────────────────────────────────────────────────────────────────────
# # Server Settings
# # ────────────────────────────────────────────────────────────────────────────
# APP_HOST=0.0.0.0
# APP_PORT=8000
# WORKERS=4


###################################################real env file for resaleAI########################################################


# ══════════════════════════════════════════════════════════════════════════════
# ResaleAI Configuration - MongoDB Storage (Development)
# ══════════════════════════════════════════════════════════════════════════════

# ── App Settings ──────────────────────────────────────────────────────────────
APP_NAME=ResaleAI
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# ── MongoDB (File & Product Storage) ──────────────────────────────────────────
# Local: mongodb://localhost:27017
# Cloud: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
MONGODB_URL=mongodb+srv://Hasibul:BfdBlfkcZpWCwPnr@nikooai.lri8ass.mongodb.net/?appName=NIkooAI
#MONGODB_URL=mongodb+srv://ajpropl-DB:EBE9eFCyiqaHM89t@cluster0.b6ov8m0.mongodb.net/ajpropl-DB?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=resale_ai

S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_BUCKET_NAME=
S3_ENDPOINT=

# ── Redis (Background Task Queue) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Gemini Vision API (Physical Dimensions) ───────────────────────────────────
# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# ── Remove.bg API (Background Removal) ────────────────────────────────────────
# Get from: https://www.remove.bg/api
 #d1d6eKhc1t2FcVZF9dXqgES7
REMOVEBG_API_KEY=

# ── Replicate API (Virtual Try-On / Mannequin / Model) ───────────────────────
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ── Hugging Face API (Alternative AI Provider) ───────────────────────────────
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=

# ── AI Provider ────────────────────────────────────────────────────────────────
# Options: HUGGINGFACE, REPLICATE, NANO_BANANA_PRO
AI_PROVIDER=HUGGINGFACE

# ── Nano Banana Pro (Model / Virtual Try-On / Mannequin) ─────────────────────
# Example:
# NANO_BANANA_FEMALE_MODEL_URLS=https://cdn.site/female1.jpg,https://cdn.site/female2.jpg
# NANO_BANANA_MALE_MODEL_URLS=https://cdn.site/male1.jpg,https://cdn.site/male2.jpg
# If GEMINI_API_KEY is set, Nano Banana can run directly via Gemini API.
# Custom base URL/API key below are optional for gateway/proxy setups.
# Leave model URL lists empty for no-reference mode (AI generates model automatically).
NANO_BANANA_PRO_API_KEY=
NANO_BANANA_PRO_BASE_URL=
NANO_BANANA_PRO_ENDPOINT_PATH=/generate
NANO_BANANA_PRO_MODEL=nano-banana-pro-preview
NANO_BANANA_PRO_TIMEOUT_SECONDS=120
NANO_BANANA_FEMALE_MODEL_URLS=
NANO_BANANA_MALE_MODEL_URLS=

# ── Google Vision API (Optional) ──────────────────────────────────────────────
GOOGLE_VISION_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# STORAGE STRATEGY: MongoDB Only
# ──────────────────────────────────────────────────────────────────────────────
# Files stored in: resale_ai.files collection
# Each image stored as binary data in MongoDB documents
# File URLs: mongodb://file-id (reference format)
#
# Benefits:
#   ✅ Zero cloud configuration needed
#   ✅ All data in one place (MongoDB)
#   ✅ Perfect for development & testing
#   ✅ No additional costs
# ══════════════════════════════════════════════════════════════════════════════
# Storage Strategy:
# 
# DEVELOPMENT (default):
#   - Images stored as binary data in MongoDB
#   - No cloud configuration needed
#   - Perfect for local development & testing
#   - Database name: resale_ai
#   - Collection: files
#   - URLs formatted as: mongodb://file-id
#
# PRODUCTION (when cloud credentials are set):
#   - Images uploaded to Cloudflare R2
#   - Set R2_ACCESS_KEY_ID and R2_ENDPOINT_URL to enable
#   - URLs formatted as: https://cdn.example.com/folder/file-id.ext
# ══════════════════════════════════════════════════════════════════════════════
